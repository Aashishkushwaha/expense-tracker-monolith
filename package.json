{
  "name": "expense-tracker-monolith",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "pnpm --filter expense-tracker-monolith-backend lint:fix",
      "pnpm --filter expense-tracker-monolith-backend format"
    ],
    "backend/tests/**/*.test.js": [
      "pnpm --filter expense-tracker-monolith-backend test"
    ],
    "frontend/**/*.{js,jsx}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}